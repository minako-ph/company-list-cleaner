# backend/.env.example — バックエンド(Cloud Run)環境変数の骨子（引継書§9）
#
# 使い方: cp backend/.env.example backend/.env して値を埋める（.envはgitignore済み）。
# 本番はCloud Runのenv/Secret Managerで設定し、シークレット値をコード・リポジトリ・ログに含めない（§9絶対規則）。
#
# ※ GAS側の設定はここではなく Script Properties で行う（引継書§6）:
#    BACKEND_URL / LICENSE_PUBKEY / USER_KEY_SALT（安定ユーザーキー用ソルト、Step5参照）

# --- 国税庁API（法人番号・インボイス共通ID。申請中: 2026-07-07提出・承認1〜1.5ヶ月） ---
# アプリケーションID(13桁)。ID到着までは空のまま。
HOUJIN_APP_ID=

# インボイスAPIの接続先。ID到着まで検証環境に向ける（§7.2）。
# 本番: https://web-api.invoice-kohyo.nta.go.jp
# 検証環境URLは公開仕様書に非掲載→ID発行時の案内で確認して設定（docs/research/invoice-webapi-v1.md）。
INVOICE_API_BASE=

# インボイス機能フラグ（FR-5）。国税庁ID到着・検証環境での照合確認まで false（縮退公開の既定値）。
INVOICE_ENABLED=false

# --- gBizINFO v2（取得済み・要件書§2の公開ゲート表） ---
GBIZINFO_API_TOKEN=

# --- Stripe（FR-10 ライセンス） ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- ライセンスキー署名（JWT: sub=stripe customer。§7.3） ---
# 秘密鍵はここ、対になる公開鍵はGAS Script Properties の LICENSE_PUBKEY へ。
LICENSE_SIGNING_KEY=

# --- レート・無料枠（既定値は引継書§9。変更時はdecisions.mdに記録） ---
# 公的APIへの直列送信レート(req/秒)。インボイスAPIは数値上限の明記なし・規約第9条の
# 大量アクセス禁止のみのため、根拠が出るまで1から上げない（decisions.md 2026-07-07）。
RATE_RPS=1
FREE_ROWS_PER_MONTH=50
PRO_ROWS_PER_MONTH=10000
